{
  "name": "postgres-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/domain tests/application",
    "test:integration": "bun test tests/adapters",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:seed": "bun run scripts/seed.ts",
    "db:reset": "docker compose down -v && docker compose up -d && bun run scripts/wait-for-db.ts && bun run scripts/migrate.ts && bun run scripts/seed.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.3",
    "ejs": "^3.1.10",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ejs": "^3.1.5",
    "typescript": "^5.6.2"
  }
}
