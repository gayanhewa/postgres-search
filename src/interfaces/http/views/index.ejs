<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Postgres Search Playground</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
      :root {
        --fg: #1a1a1a;
        --muted: #666;
        --bg: #fafafa;
        --card: #fff;
        --accent: #0066cc;
        --border: #e5e5e5;
      }
      * { box-sizing: border-box; }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        color: var(--fg);
        background: var(--bg);
        margin: 0;
        padding: 24px;
        max-width: 1400px;
        margin-inline: auto;
      }
      h1 { margin: 0 0 4px; }
      .sub { color: var(--muted); margin: 0 0 24px; }
      .controls {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 16px;
      }
      input[type="text"] {
        flex: 1 1 320px;
        min-width: 240px;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 15px;
      }
      button {
        padding: 10px 14px;
        border: 1px solid var(--border);
        background: var(--card);
        border-radius: 6px;
        cursor: pointer;
        font-size: 14px;
      }
      button.primary {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
      }
      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
      }
      @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
      .panel {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 14px;
        min-height: 120px;
      }
      .panel h2 {
        margin: 0 0 4px;
        font-size: 15px;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .panel p.hint { margin: 0 0 10px; color: var(--muted); font-size: 13px; }
      .hit {
        border-top: 1px solid var(--border);
        padding: 10px 0;
      }
      .hit:first-of-type { border-top: none; }
      .hit .title { font-weight: 600; margin-bottom: 4px; }
      .hit .body { color: #333; font-size: 14px; line-height: 1.45; }
      .hit .meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        font-size: 12px;
        color: var(--muted);
        margin-top: 6px;
      }
      .score { font-variant-numeric: tabular-nums; }
      .empty { color: var(--muted); font-size: 14px; }
      .loading { color: var(--muted); font-size: 14px; }
      code { background: #f0f0f0; padding: 1px 4px; border-radius: 3px; font-size: 13px; }
    </style>
  </head>
  <body x-data="search()">
    <h1>Postgres Search Playground</h1>
    <p class="sub">Same query, three engines: tsvector full-text, pgvector similarity, and a hybrid blend.</p>

    <form class="controls" @submit.prevent="runAll()">
      <input type="text" x-model="q" placeholder='Try: "postgres index performance" or a typo like "postgers"' autofocus />
      <button type="submit" class="primary" :disabled="loading">Search</button>
      <button type="button" @click="setExample('postgres indexing')">example 1</button>
      <button type="button" @click="setExample('database performance tuning')">example 2</button>
      <button type="button" @click="setExample('pgvector similarity')">example 3</button>
    </form>

    <div class="grid">
      <section class="panel">
        <h2>tsvector / tsquery</h2>
        <p class="hint">Keyword match using <code>websearch_to_tsquery</code> and <code>ts_rank_cd</code>.</p>
        <template x-if="loading"><div class="loading">searching...</div></template>
        <template x-if="!loading && text.length === 0"><div class="empty">no hits</div></template>
        <template x-for="h in text" :key="'t-' + h.id">
          <div class="hit">
            <div class="title" x-text="h.title"></div>
            <div class="body" x-text="truncate(h.body, 220)"></div>
            <div class="meta">
              <span class="score">score <span x-text="h.score"></span></span>
              <span>id <span x-text="h.id"></span></span>
              <span x-show="h.tags && h.tags.length" x-text="'tags: ' + (h.tags || []).join(', ')"></span>
            </div>
          </div>
        </template>
      </section>

      <section class="panel">
        <h2>pgvector</h2>
        <p class="hint">Cosine similarity with the <code>&lt;=&gt;</code> operator on 128-dim fake embeddings.</p>
        <template x-if="loading"><div class="loading">searching...</div></template>
        <template x-if="!loading && vector.length === 0"><div class="empty">no hits</div></template>
        <template x-for="h in vector" :key="'v-' + h.id">
          <div class="hit">
            <div class="title" x-text="h.title"></div>
            <div class="body" x-text="truncate(h.body, 220)"></div>
            <div class="meta">
              <span class="score">cos sim <span x-text="h.score"></span></span>
              <span>id <span x-text="h.id"></span></span>
            </div>
          </div>
        </template>
      </section>

      <section class="panel">
        <h2>hybrid</h2>
        <p class="hint">Min-max normalized scores blended 50/50.</p>
        <template x-if="loading"><div class="loading">searching...</div></template>
        <template x-if="!loading && hybrid.length === 0"><div class="empty">no hits</div></template>
        <template x-for="h in hybrid" :key="'h-' + h.id">
          <div class="hit">
            <div class="title" x-text="h.title"></div>
            <div class="body" x-text="truncate(h.body, 220)"></div>
            <div class="meta">
              <span class="score">blended <span x-text="h.score"></span></span>
              <span>id <span x-text="h.id"></span></span>
            </div>
          </div>
        </template>
      </section>
    </div>

    <script>
      function search() {
        return {
          q: "",
          loading: false,
          text: [],
          vector: [],
          hybrid: [],
          setExample(v) { this.q = v; this.runAll(); },
          truncate(s, n) { return s && s.length > n ? s.slice(0, n) + "..." : s; },
          async runAll() {
            if (!this.q.trim()) { this.text = []; this.vector = []; this.hybrid = []; return; }
            this.loading = true;
            try {
              const [t, v, h] = await Promise.all([
                fetch("/api/search?q=" + encodeURIComponent(this.q)).then(r => r.json()),
                fetch("/api/vector?q=" + encodeURIComponent(this.q)).then(r => r.json()),
                fetch("/api/hybrid?q=" + encodeURIComponent(this.q)).then(r => r.json()),
              ]);
              this.text = t.hits || [];
              this.vector = v.hits || [];
              this.hybrid = h.hits || [];
            } finally {
              this.loading = false;
            }
          }
        };
      }
    </script>
  </body>
</html>
